# Raw firmware dumps — not distributed (size + licensing)
Firmware_Backups/
JMR540_Firmware/

# Extracted/staged binaries from commercial firmware — not distributed
PortableApps/

# Original research working documents
Private_Research/*.pdf
Private_Research/*.docx
Private_Research/*.doc

# Local IDE/assistant session files
.claude/

# Device-specific binary blobs
device_config

# Local system / editor artifacts
*.pyc
__pycache__/
.DS_Store
Thumbs.db

# Allow source link files and deploy/control scripts within ignored dirs
\!PortableApps/**/SOURCES.txt
\!PortableApps/**/*.sh

# Allow RayTrap web UI (26_raytrap) — shell CGI scripts, HTML, and init script
\!PortableApps/26_raytrap/**/*.cgi
\!PortableApps/26_raytrap/**/index.html
\!PortableApps/26_raytrap/**/raytrap_daemon
\!PortableApps/26_raytrap/**/tinyproxy.conf
