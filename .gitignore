# Raw firmware dumps — not distributed (size + licensing)
Firmware_Backups/
JMR540_Firmware/

# Extracted/staged binaries from commercial firmware — not distributed
PortableApps/

# Original research working documents
Private_Research/*.pdf
Private_Research/*.docx
Private_Research/*.doc

# Local IDE/assistant session files
.claude/

# AT command fuzzing research — private, not for public repo
Private_Research/at_fuzz/

# ALL local operational files: scripts, scratch, device config, binaries
# Add new local files here — never add them to root
Local/

# Third-party tool installs
qcsuper/

# Capture files — potentially sensitive
*.pcap
*.pcapng

# Local system / editor artifacts
*.pyc
__pycache__/
.DS_Store
Thumbs.db

# Allow source link files and deploy/control scripts within ignored dirs
!PortableApps/**/SOURCES.txt
!PortableApps/**/*.sh
!PortableApps/**/*.py

# Allow RayTrap web UI (26_raytrap) — CGI scripts, HTML, init script, build scripts, patched source
!PortableApps/26_raytrap/**/*.cgi
!PortableApps/26_raytrap/**/index.html
!PortableApps/26_raytrap/**/raytrap_daemon
!PortableApps/26_raytrap/**/tinyproxy.conf
!PortableApps/26_raytrap/rh_build.sh
!PortableApps/26_raytrap/rh_deploy.sh
!PortableApps/26_raytrap/rayhunter_fork/daemon/src/main.rs
